version: '3.8'

services:
  api:
    # Override: Use local code for live development
    volumes:
      - ./src:/app/src
      - ./data:/app/data
      - ./logs:/app/logs
      - ./models:/app/models
    environment:
      - LOG_LEVEL=DEBUG
      - PYTHONDONTWRITEBYTECODE=1

  tests:
    # Override: Use local code
    volumes:
      - ./src:/app/src
      - ./tests:/app/tests
